{
  "snakeAnimation": {
    "general": {
      "username": "HarshNexus",
      "updateFrequency": "daily",
      "autoUpdateTime": "02:00 UTC",
      "cacheDuration": "24h"
    },
    "dimensions": {
      "lightMode": {
        "width": 1200,
        "height": 250
      },
      "darkMode": {
        "width": 1200,
        "height": 250
      },
      "minimal": {
        "width": 1200,
        "height": 200
      }
    },
    "colors": {
      "lightMode": {
        "background": "#ffffff",
        "grid": "#f0f0f0",
        "gridOpacity": 0.3,
        "trail": ["#FF006E", "#FB5607", "#FFBE0B", "#8338EC"],
        "glow": ["#FF006E", "#FB5607", "#FFBE0B", "#8338EC"],
        "particles": "#FF006E",
        "text": "#000000",
        "accent": "#8338EC"
      },
      "darkMode": {
        "background": "#0a0e27",
        "grid": "#1a1f3a",
        "gridOpacity": 0.15,
        "trail": ["#FF006E", "#00D9FF", "#39FF14", "#FF10F0"],
        "glow": ["#FF006E", "#00D9FF", "#39FF14", "#FF10F0"],
        "particles": "#00D9FF",
        "text": "#00D9FF",
        "accent": "#39FF14"
      }
    },
    "animation": {
      "snakeSlither": {
        "duration": "4s",
        "timingFunction": "linear",
        "iterationCount": "infinite"
      },
      "headPulse": {
        "duration": "1.5s",
        "timingFunction": "ease-in-out",
        "iterationCount": "infinite"
      },
      "particleFloat": {
        "duration": "2s",
        "timingFunction": "ease-out"
      }
    },
    "effects": {
      "glow": {
        "enabled": true,
        "standardDeviation": 3,
        "type": "normal"
      },
      "strongGlow": {
        "enabled": true,
        "standardDeviation": 5,
        "type": "double-pass",
        "appliedTo": "snakeHead"
      },
      "particles": {
        "enabled": true,
        "count": 30,
        "behavior": "float"
      },
      "obstacles": {
        "enabled": true,
        "count": 5,
        "opacity": 0.3,
        "style": "rounded-square"
      },
      "grid": {
        "enabled": true,
        "spacing": 20,
        "lineWidth": 0.5
      }
    },
    "snakes": {
      "count": 2,
      "snake1": {
        "colorScheme": "pinkOrange",
        "offset": "0s",
        "size": "normal"
      },
      "snake2": {
        "colorScheme": "cyanGreen",
        "offset": "1.5s",
        "size": "normal"
      }
    },
    "customization": {
      "text": {
        "enabled": true,
        "content": "Harsh Nexus Dev",
        "fontSize": 24,
        "fontWeight": "bold",
        "position": "top",
        "yOffset": 40
      },
      "attribution": {
        "enabled": true,
        "text": "Generated by Harsh Nexus Custom Snake Generator",
        "fontSize": 10,
        "position": "bottom"
      }
    },
    "pathfinding": {
      "algorithm": "intelligentHunt",
      "maxPathLength": 100,
      "contributonWeight": 0.8,
      "randomnessWeight": 0.2
    },
    "performance": {
      "svgOptimization": true,
      "compressionLevel": "medium",
      "responsiveScaling": true
    },
    "output": {
      "formats": ["svg"],
      "variants": [
        "light",
        "dark",
        "minimal"
      ],
      "directory": "dist/",
      "filenames": {
        "light": "github-contribution-grid-snake.svg",
        "dark": "github-contribution-grid-snake-dark.svg",
        "minimal": "github-contribution-grid-snake-minimal.svg"
      }
    },
    "deployment": {
      "platform": "github",
      "branch": "output",
      "cdnUrl": "https://raw.githubusercontent.com",
      "autoUpdate": true,
      "failureRetry": {
        "enabled": true,
        "maxAttempts": 3,
        "delaySeconds": 300
      }
    }
  }
}
